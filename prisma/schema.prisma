generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- Organization Management ---

model Organization {
  id          String       @id @default(uuid())
  name        String
  code        String       @unique
  departments Department[]
  users       User[]
  projects    Project[]
  workflows   Workflow[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Department {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  teams          Team[]
  users          User[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Team {
  id           String     @id @default(uuid())
  name         String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  users        User[]
  projects     Project[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// --- User & RBAC ---

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String
  fullName       String
  phone          String?
  avatar         String?
  position       String?
  jobTitle       String?
  status         UserStatus    @default(ACTIVE)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  departmentId   String?
  department     Department?   @relation(fields: [departmentId], references: [id])
  teamId         String?
  team           Team?         @relation(fields: [teamId], references: [id])
  roleId         String
  role           Role          @relation(fields: [roleId], references: [id])
  managerId      String?
  manager        User?         @relation("ManagerSubordinate", fields: [managerId], references: [id])
  subordinates   User[]        @relation("ManagerSubordinate")
  projects       Project[]     @relation("ProjectOwner")
  tasks          Task[]        @relation("TaskAssignee")
  assignedSteps  WorkflowStep[] @relation("StepAssignee")
  comments       Comment[]
  notifications  Notification[]
  activityLogs   ActivityLog[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., "project.create"
  roles     Role[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Project Management ---

model Project {
  id             String        @id @default(uuid())
  name           String
  code           String        @unique
  description    String?
  startDate      DateTime?
  dueDate        DateTime?
  priority       Priority      @default(MEDIUM)
  status         ProjectStatus @default(DRAFT)
  ownerId        String
  owner          User          @relation("ProjectOwner", fields: [ownerId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  teamId              String?
  team                Team?         @relation(fields: [teamId], references: [id])
  workflowTemplateId  String?
  workflowTemplate    Workflow?     @relation("ProjectWorkflowTemplate", fields: [workflowTemplateId], references: [id])
  instances           WorkflowInstance[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

// --- Workflow Builder ---

model Workflow {
  id             String             @id @default(uuid())
  name           String
  description    String?
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id])
  steps          WorkflowStep[]
  instances      WorkflowInstance[]
  projects       Project[]          @relation("ProjectWorkflowTemplate")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model WorkflowStep {
  id              String         @id @default(uuid())
  workflowId      String
  workflow        Workflow       @relation(fields: [workflowId], references: [id])
  name            String
  description     String?
  color           String?
  icon            String?
  sla             Int?           // in hours
  estimatedHours  Float?         // estimated hours for this step
  order           Int
  formSchema      Json?          // Dynamic form fields
  type            StepType       @default(FORM)
  config          Json?          // Logic, branching, etc.
  assignedUserId  String?
  assignedUser    User?          @relation("StepAssignee", fields: [assignedUserId], references: [id])
  instances       WorkflowInstanceStep[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum StepType {
  START
  FORM
  APPROVAL
  CONDITION
  NOTIFICATION
  FINISH
}

model WorkflowInstance {
  id          String           @id @default(uuid())
  workflowId  String
  workflow    Workflow         @relation(fields: [workflowId], references: [id])
  projectId   String?
  project     Project?         @relation(fields: [projectId], references: [id])
  title       String
  status      InstanceStatus   @default(CREATED)
  currentStepId String?
  steps       WorkflowInstanceStep[]
  tasks       Task[]
  comments    Comment[]
  attachments Attachment[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

enum InstanceStatus {
  CREATED
  IN_PROGRESS
  WAITING_APPROVAL
  REJECTED
  COMPLETED
}

model WorkflowInstanceStep {
  id              String           @id @default(uuid())
  instanceId      String
  instance        WorkflowInstance @relation(fields: [instanceId], references: [id])
  stepId          String
  step            WorkflowStep     @relation(fields: [stepId], references: [id])
  formData        Json?
  status          StepStatus       @default(PENDING)
  estimatedHours  Float?
  actualHours     Float?
  startedAt       DateTime?
  completedBy     String?
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

// --- Task Management ---

model Task {
  id              String           @id @default(uuid())
  instanceId      String?
  instance        WorkflowInstance? @relation(fields: [instanceId], references: [id])
  instanceStepId  String?
  title           String
  description     String?
  assigneeId      String?
  assignee        User?            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  dueDate         DateTime?
  priority        Priority         @default(MEDIUM)
  status          TaskStatus       @default(TODO)
  estimatedHours  Float?
  actualHours     Float?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

// --- Utilities ---

model Comment {
  id          String           @id @default(uuid())
  instanceId  String
  instance    WorkflowInstance @relation(fields: [instanceId], references: [id])
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  content     String
  attachments Attachment[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Attachment {
  id          String           @id @default(uuid())
  instanceId  String?
  instance    WorkflowInstance? @relation(fields: [instanceId], references: [id])
  commentId   String?
  comment     Comment?         @relation(fields: [commentId], references: [id])
  filename    String
  path        String
  size        Int
  mimetype    String
  uploaderId  String
  createdAt   DateTime         @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  details   Json?
  createdAt DateTime @default(now())
}
